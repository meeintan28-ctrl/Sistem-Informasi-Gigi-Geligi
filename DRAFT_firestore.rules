rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    // Default Deny
    match /{document=**} {
      allow read, write: if false;
    }

    // Helper Functions
    function isSignedIn() {
      return request.auth != null;
    }

    function isVerified() {
      return isSignedIn() && request.auth.token.email_verified == true;
    }

    function getUserData() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data;
    }

    function hasRole(role) {
      return isVerified() && getUserData().role == role;
    }

    function hasAnyRole(roles) {
      return isVerified() && getUserData().role in roles;
    }

    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    function incoming() {
      return request.resource.data;
    }

    function existing() {
      return resource.data;
    }

    // --- USERS ---
    match /users/{userId} {
      allow get: if isSignedIn() && (request.auth.uid == userId || hasRole('admin'));
      allow list: if hasRole('admin');
      
      function isValidUser(data) {
        return data.keys().hasAll(['uid', 'email', 'role']) &&
               data.uid == userId &&
               data.uid == request.auth.uid &&
               data.role in ['admin', 'dokter', 'terapis', 'staff'] &&
               data.email is string && data.email.size() <= 200;
      }

      allow create: if isSignedIn() && isValidUser(incoming()) && 
                    incoming().role == 'terapis'; // Default role for self-reg if allowed
      
      allow update: if isVerified() && (
        (request.auth.uid == userId && incoming().diff(existing()).affectedKeys().hasOnly(['displayName'])) ||
        (hasRole('admin') && incoming().diff(existing()).affectedKeys().hasOnly(['role']))
      );
    }

    // --- PATIENTS ---
    match /patients/{patientId} {
      allow get: if isVerified();
      allow list: if isVerified() && resource.data.createdBy == request.auth.uid || hasAnyRole(['admin', 'dokter']);

      function isValidPatient(data) {
        return data.keys().hasAll(['name', 'nik', 'rm', 'gender']) &&
               data.name is string && data.name.size() <= 100 &&
               data.nik is string && data.nik.size() == 16 &&
               data.rm is string && data.rm.size() <= 50 &&
               data.gender in ['L', 'P'] &&
               (request.method == 'create' ? data.createdBy == request.auth.uid : true);
      }

      allow create: if isVerified() && isValidId(patientId) && isValidPatient(incoming());
      allow update: if isVerified() && isValidPatient(incoming()) && 
                    (existing().createdBy == request.auth.uid || hasAnyRole(['admin', 'dokter'])) &&
                    incoming().diff(existing()).affectedKeys().hasOnly(['name', 'address', 'phone', 'lastVisit']);
    }

    // --- MEDICAL RECORDS ---
    match /records/{recordId} {
      allow get: if isVerified();
      allow list: if isVerified(); // Strictly should filter by patientId or operatorId in query

      function isValidRecord(data) {
         return data.keys().hasAll(['patientId', 'operatorId', 'date', 'status']) &&
                isValidId(data.patientId) &&
                data.operatorId == request.auth.uid &&
                data.status in ['draft', 'final'] &&
                exists(/databases/$(database)/documents/patients/$(data.patientId)) &&
                data.createdAt == request.time;
      }

      allow create: if isVerified() && isValidId(recordId) && isValidRecord(incoming()) && hasAnyRole(['admin', 'dokter', 'terapis']);
      
      allow update: if isVerified() && 
                    existing().status == 'draft' &&
                    existing().operatorId == request.auth.uid &&
                    incoming().operatorId == existing().operatorId &&
                    incoming().patientId == existing().patientId &&
                    incoming().diff(existing()).affectedKeys().hasOnly(['anamnesis', 'indices', 'odontogram', 'diagnoses', 'interventions', 'notes', 'status', 'updatedAt']) &&
                    incoming().updatedAt == request.time;
      
      allow delete: if hasRole('admin');
    }

    // --- APPOINTMENTS ---
    match /appointments/{appointmentId} {
      allow read: if isVerified();
      allow write: if isVerified() && isValidId(appointmentId);
    }
  }
}
